# Cron job to run full backup script every hour
0 * * * * /usr/local/bin/node /app/scripts/fullBackup.js >> /var/log/cron.log 2>&1

# Cron job to notify customers if vehicle which picks them up changes
* * * * * /usr/local/bin/node /app/scripts/sendNewVehicleNotice.js >> /var/log/cron.log 2>&1

# Cron job to remind customers and companies of imminent journeys
*/5 * * * * /usr/local/bin/node /app/scripts/sendReminder.js >> /var/log/cron.log 2>&1

# Cron job to store current availability states
* * * * * /usr/local/bin/node /app/scripts/captureAvailabilityState.js >> /var/log/cron.log 2>&1

30 3 2 * * /usr/local/bin/node /app/scripts/availabilityCompensation.js >> /var/log/cron.log 2>&1
